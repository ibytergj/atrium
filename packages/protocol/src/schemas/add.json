{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Add",
  "description": "Add a node to the scene graph",
  "type": "object",
  "required": ["type", "seq", "node"],
  "properties": {
    "type": { "const": "add" },
    "seq": { "type": "integer", "minimum": 0 },
    "id": { "type": "string", "description": "Session UUID — identifies the sender when adding an avatar node" },
    "format": { "type": "string", "default": "gltf" },
    "parent": { "type": ["string", "null"] },
    "node": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "translation": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "rotation": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "scale": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "extras": { "type": "object" },
        "extensions": { "type": "object" },
        "mesh": {
          "type": "object",
          "description": "glTF mesh descriptor with primitives including geometry and material",
          "properties": {
            "name": { "type": "string" },
            "primitives": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "attributes": { "type": "object" },
                  "indices": {},
                  "material": { "type": "object" }
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}